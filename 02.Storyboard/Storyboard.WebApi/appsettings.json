{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "Provider": "Sqlite"
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=storyboard_web;Username=postgres;Password=postgres",
    "Sqlite": "Data Source=storyboard-web.db"
  },
  "Jwt": {
    "Key": "dev-secret-key-change-in-production-min-32-chars!!",
    "Issuer": "StoryboardWeb",
    "Audience": "StoryboardWeb",
    "ExpiresInMinutes": 60
  },
  "Cors": {
    "Origins": [ "http://localhost:3000" ]
  },
  "ImageGeneration": {
    "Provider": "Mock"
  },
  "OpenAI": {
    "ApiKey": ""
  }
}
